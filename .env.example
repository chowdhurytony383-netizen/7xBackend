# SportMonks Cricket + Football sports mode
SPORTS_PROVIDER=sportmonks
SPORTS_ODDS_PROVIDER=sportmonks
SPORTS_DETAILS_PROVIDER=sportmonks
SPORTS_SCORE_PROVIDER=sportmonks

# If your SportMonks account uses one token for both products, put the same token
# in SPORTMONKS_CRICKET_API_TOKEN and SPORTMONKS_FOOTBALL_API_TOKEN.
SPORTMONKS_CRICKET_ENABLED=true
SPORTMONKS_CRICKET_API_TOKEN=your_sportmonks_cricket_token
SPORTMONKS_CRICKET_BASE_URL=https://cricket.sportmonks.com/api/v2.0
SPORTMONKS_CRICKET_INCLUDE=localteam,visitorteam,league,season,stage,venue,scoreboards,runs,balls,batting,bowling,lineup,tosswon,manofmatch,manofseries,odds
SPORTMONKS_CRICKET_FIXTURE_DAYS_PAST=1
SPORTMONKS_CRICKET_FIXTURE_DAYS_FUTURE=30
SPORTMONKS_CRICKET_MAX_PAGES=2
SPORTMONKS_CRICKET_TIMEOUT_MS=12000

SPORTMONKS_FOOTBALL_ENABLED=true
SPORTMONKS_FOOTBALL_API_TOKEN=your_sportmonks_football_token
SPORTMONKS_FOOTBALL_BASE_URL=https://api.sportmonks.com/v3/football
SPORTMONKS_FOOTBALL_INCLUDE=participants;league;season;stage;round;venue;state;scores
SPORTMONKS_FOOTBALL_FIXTURE_DAYS_PAST=1
SPORTMONKS_FOOTBALL_FIXTURE_DAYS_FUTURE=14
SPORTMONKS_FOOTBALL_MAX_PAGES=2
SPORTMONKS_FOOTBALL_TIMEOUT_MS=12000
SPORTMONKS_FOOTBALL_H2H_MARKET_IDS=1
SPORTMONKS_FOOTBALL_BOOKMAKER_IDS=
SPORTMONKS_FOOTBALL_MAX_ODDS_FIXTURES=40
SPORTMONKS_FOOTBALL_INPLAY_ODDS_ENABLED=true

# Old providers disabled in SportMonks-only mode.
APISPORTS_API_KEY=
THE_ODDS_API_KEY=
SPORTS_ODDS_API_KEY=

SPORTS_AUTO_SYSTEM_ENABLED=true
SPORTS_AUTO_SYNC_ON_REQUEST=false
SPORTS_AUTO_SYNC_ACTIVE_SPORTS=true
SPORTS_AUTO_SPORT_KEYS=cricket,football
SPORTS_AUTO_MAX_SPORTS_PER_SYNC=2

SPORTS_DEFAULT_MARKETS=h2h
SPORTS_ODDS_FORMAT=decimal
SPORTS_USE_PROVIDER_ODDS_ONLY=true
SPORTS_USE_BOOK_ODDS_ONLY=true
SPORTS_REQUIRE_REAL_ODDS=true
SPORTS_DISABLE_FAKE_ODDS=true
SPORTS_DISABLE_SYNTHETIC_ODDS=true
SPORTS_HIDE_EVENTS_WITHOUT_ODDS=true

SPORTS_ODDS_SYNC_TTL_SECONDS=60
SPORTS_SCORE_SYNC_TTL_SECONDS=30
SPORTS_RESPONSE_CACHE_SECONDS=15
SPORTS_DETAILS_CACHE_SECONDS=120
SPORTS_HIDE_STARTED_OLDER_HOURS=48

SPORTS_MIN_STAKE=1
SPORTS_MAX_STAKE=500
SPORTS_AUTO_SETTLEMENT_ENABLED=true
SPORTS_AUTO_SETTLEMENT_MIN_DELAY_MINUTES=15
SPORTS_AUTO_REVIEW_ABOVE_AMOUNT=0

# Signup bonus / Withdraw rules
# Every new account receives BDT 100 equivalent in the user's registered currency.
SIGNUP_BONUS_ENABLED=true
SIGNUP_BONUS_BASE_AMOUNT_BDT=100
SIGNUP_BONUS_TURNOVER_MULTIPLIER=2
# Optional: set manual BDT -> currency rates if you do not want fallback rates.
# Example: {"USD":0.0082,"INR":0.68,"PKR":2.28}
SIGNUP_BONUS_BDT_RATES_JSON=
# Optional: directly set exact bonus amount per currency.
# Example: {"BDT":100,"INR":68,"USD":0.82}
SIGNUP_BONUS_AMOUNT_BY_CURRENCY_JSON=
SIGNUP_BONUS_EXCHANGE_API_URL=
SIGNUP_BONUS_USE_LIVE_RATES=true
SIGNUP_BONUS_RATE_CACHE_MS=21600000

# Legacy first-deposit bonus is OFF by default because signup bonus is active.
FIRST_DEPOSIT_BONUS_ENABLED=false

# No account/KYC document verification required for withdraw/deposit/bonus.
WITHDRAW_KYC_REQUIRED=false
WITHDRAW_TURNOVER_REQUIRED=true
# Deposit turnover can remain 50% unless you set another value.
WITHDRAW_DEPOSIT_TURNOVER_MULTIPLIER=0.5
# Bonus 100 equivalent requires 200 equivalent bets before withdrawal.
WITHDRAW_BONUS_TURNOVER_MULTIPLIER=2
WITHDRAW_TURNOVER_MULTIPLIER=1

# Agent commission rules
# Deposit 100 => 6 commission, withdraw 100 => 2 commission.
AGENT_DEPOSIT_COMMISSION_RATE=0.06
AGENT_WITHDRAW_COMMISSION_RATE=0.02
AGENT_COMMISSION_PAYOUT_DAY=3
AGENT_COMMISSION_AUTO_PAYOUT=true
AGENT_COMMISSION_PAYOUT_TIMEZONE=Asia/Dhaka
AGENT_COMMISSION_PAYOUT_CHECK_MS=3600000
