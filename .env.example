NODE_ENV=development
PORT=3000
MONGO_URI=mongodb://127.0.0.1:27017/7xbet
FRONTEND_URL=http://localhost:5174
CORS_ORIGIN=http://localhost:5174
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d
COOKIE_SECURE=false

# First admin created by npm run seed
ADMIN_NAME=7XBET Admin
ADMIN_EMAIL=admin@7xbet.local
ADMIN_PASSWORD=Admin@123456

# Razorpay deposit order/verify. If not set, backend uses dev orders.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAYX_ACCOUNT_NUMBER=

# Optional OAuth. If blank, /api/auth/google and /api/auth/facebook create dev social sessions.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
OAUTH_CALLBACK_BASE_URL=http://localhost:3000


# Production example for Render/domain
# FRONTEND_URL=https://7xbet.asia
# CORS_ORIGIN=https://7xbet.asia,https://www.7xbet.asia
# COOKIE_SECURE=true

# Crypto withdraw / payout settings
# Keep DRY_RUN=true until you test everything with a small amount.
CRYPTO_WITHDRAW_ENABLED=false
CRYPTO_WITHDRAW_DRY_RUN=true
CRYPTO_WITHDRAW_ALLOWED_METHODS=BNB,USDT_BEP20,USDT_TRC20,ETH,USDT_ERC20
CRYPTO_WITHDRAW_MIN_FIAT=100
CRYPTO_WITHDRAW_MAX_FIAT=25000
CRYPTO_WITHDRAW_FIAT=BDT

# Recommended: use Tatum KMS/signatureId, not raw private keys.
CRYPTO_WITHDRAW_BSC_SIGNATURE_ID=
CRYPTO_WITHDRAW_BSC_INDEX=0
CRYPTO_WITHDRAW_BSC_PRIVATE_KEY=
CRYPTO_WITHDRAW_BSC_GAS_LIMIT=30000
CRYPTO_WITHDRAW_BSC_GAS_PRICE=

CRYPTO_WITHDRAW_ETH_SIGNATURE_ID=
CRYPTO_WITHDRAW_ETH_INDEX=0
CRYPTO_WITHDRAW_ETH_PRIVATE_KEY=

CRYPTO_WITHDRAW_TRON_SIGNATURE_ID=
CRYPTO_WITHDRAW_TRON_INDEX=0
CRYPTO_WITHDRAW_TRON_PRIVATE_KEY=
CRYPTO_WITHDRAW_TRON_FEE_LIMIT=100
