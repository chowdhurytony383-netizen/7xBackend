NODE_ENV=development
PORT=3000
MONGO_URI=mongodb://127.0.0.1:27017/7xbet
FRONTEND_URL=http://localhost:5174
CORS_ORIGIN=http://localhost:5174
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d
COOKIE_SECURE=false

# First admin created by npm run seed
ADMIN_NAME=7XBET Admin
ADMIN_EMAIL=admin@7xbet.local
ADMIN_PASSWORD=Admin@123456

# Razorpay deposit order/verify. If not set, backend uses dev orders.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAYX_ACCOUNT_NUMBER=

# Optional OAuth. If blank, /api/auth/google and /api/auth/facebook create dev social sessions.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
OAUTH_CALLBACK_BASE_URL=http://localhost:3000


# Production example for Render/domain
# FRONTEND_URL=https://7xbet.asia
# CORS_ORIGIN=https://7xbet.asia,https://www.7xbet.asia
# COOKIE_SECURE=true


# Admin/agent panels may use 1-second API polling. Keep this high enough to avoid 429 rate-limit errors.
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=10000

# Email OTP / SMTP. Use only backend env in Render. Do not put SMTP_PASS in frontend.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_digit_app_password
MAIL_FROM_NAME=7XBET
MAIL_FROM_EMAIL=your_email@gmail.com
EMAIL_OTP_EXPIRES_MINUTES=10
EMAIL_OTP_RESEND_COOLDOWN_SECONDS=60
EMAIL_OTP_MAX_ATTEMPTS=5


# Automatic sports betting system (free/low-cost provider)
SPORTS_AUTO_SYSTEM_ENABLED=true
SPORTS_AUTO_SYNC_ON_REQUEST=true
SPORTS_ODDS_PROVIDER=theoddsapi
SPORTS_ODDS_API_KEY=your_free_the_odds_api_key
SPORTS_AUTO_SPORT_KEYS=soccer_epl,soccer_uefa_champs_league,cricket_test_match,cricket_odi,cricket_t20,basketball_nba,tennis_atp_singles,tennis_wta_singles
SPORTS_DEFAULT_REGIONS=us,uk,eu
SPORTS_DEFAULT_MARKETS=h2h
SPORTS_ODDS_FORMAT=decimal
SPORTS_PREFERRED_BOOKMAKERS=bet365,pinnacle,williamhill,betfair,unibet
SPORTS_ODDS_SYNC_TTL_SECONDS=60
SPORTS_SCORE_SYNC_TTL_SECONDS=90
SPORTS_ODDS_STALE_SECONDS=900
SPORTS_MIN_STAKE=1
SPORTS_MAX_STAKE=500
SPORTS_AUTO_SETTLEMENT_ENABLED=true
SPORTS_AUTO_SETTLEMENT_MIN_DELAY_MINUTES=15
SPORTS_AUTO_REVIEW_ABOVE_AMOUNT=0
