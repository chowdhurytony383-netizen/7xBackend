NODE_ENV=development
PORT=3000
MONGO_URI=mongodb://127.0.0.1:27017/7xbet
FRONTEND_URL=http://localhost:5174
CORS_ORIGIN=http://localhost:5174
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d
COOKIE_SECURE=false

# First admin created by npm run seed
ADMIN_NAME=7XBET Admin
ADMIN_EMAIL=admin@7xbet.local
ADMIN_PASSWORD=Admin@123456

# Razorpay deposit order/verify. If not set, backend uses dev orders.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAYX_ACCOUNT_NUMBER=

# Optional OAuth. If blank, /api/auth/google and /api/auth/facebook create dev social sessions.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
OAUTH_CALLBACK_BASE_URL=http://localhost:3000


# Production example for Render/domain
# FRONTEND_URL=https://7xbet.asia
# CORS_ORIGIN=https://7xbet.asia,https://www.7xbet.asia
# COOKIE_SECURE=true


# Admin/agent panels may use 1-second API polling. Keep this high enough to avoid 429 rate-limit errors.
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=10000
