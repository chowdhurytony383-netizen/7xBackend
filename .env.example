SPORTS_AUTO_SYSTEM_ENABLED=true
SPORTS_AUTO_SYNC_ON_REQUEST=true
SPORTS_ODDS_PROVIDER=apisports
SPORTS_DETAILS_PROVIDER=apisports
APISPORTS_API_KEY=your_api_sports_key
APISPORTS_CACHE_SECONDS=120
APISPORTS_TIMEOUT_MS=12000
APISPORTS_MATCH_THRESHOLD=0.35
# Optional: limit API-SPORTS calls to protect quota.
APISPORTS_SYNC_DAYS_BACK=0
APISPORTS_SYNC_DAYS_AHEAD=2
APISPORTS_EVENTS_PER_SPORT=12
# If you switch back to The Odds API, set SPORTS_ODDS_PROVIDER=theoddsapi and use SPORTS_ODDS_API_KEY.
SPORTS_ODDS_API_KEY=

# all = provider থেকে free plan-এ available active sports auto fetch করবে
SPORTS_AUTO_SPORT_KEYS=all
SPORTS_AUTO_SYNC_ACTIVE_SPORTS=true
SPORTS_ACTIVE_SPORTS_TTL_SECONDS=1800
SPORTS_AUTO_MAX_SPORTS_PER_SYNC=12

SPORTS_DEFAULT_REGIONS=us,uk,eu,au
SPORTS_DEFAULT_MARKETS=h2h
SPORTS_ODDS_FORMAT=decimal
SPORTS_PREFERRED_BOOKMAKERS=bet365,pinnacle,williamhill,betfair,unibet

# Realtime-like auto refresh. Free API quota বাঁচাতে 10-30 sec ভালো।
SPORTS_ODDS_SYNC_TTL_SECONDS=30
SPORTS_SCORE_SYNC_TTL_SECONDS=30
SPORTS_HIDE_STARTED_OLDER_HOURS=24

SPORTS_MIN_STAKE=1
SPORTS_MAX_STAKE=50
SPORTS_AUTO_SETTLEMENT_ENABLED=true
SPORTS_AUTO_SETTLEMENT_MIN_DELAY_MINUTES=15
SPORTS_AUTO_REVIEW_ABOVE_AMOUNT=0


# Signup bonus / Withdraw rules
# Every new account receives BDT 100 equivalent in the user's registered currency.
SIGNUP_BONUS_ENABLED=true
SIGNUP_BONUS_BASE_AMOUNT_BDT=100
SIGNUP_BONUS_TURNOVER_MULTIPLIER=2
# Optional: set manual BDT -> currency rates if you do not want fallback rates.
# Example: {"USD":0.0082,"INR":0.68,"PKR":2.28}
SIGNUP_BONUS_BDT_RATES_JSON=
# Optional: directly set exact bonus amount per currency.
# Example: {"BDT":100,"INR":68,"USD":0.82}
SIGNUP_BONUS_AMOUNT_BY_CURRENCY_JSON=
SIGNUP_BONUS_EXCHANGE_API_URL=
SIGNUP_BONUS_USE_LIVE_RATES=true
SIGNUP_BONUS_RATE_CACHE_MS=21600000

# Legacy first-deposit bonus is OFF by default because signup bonus is active.
FIRST_DEPOSIT_BONUS_ENABLED=false

# No account/KYC document verification required for withdraw/deposit/bonus.
WITHDRAW_KYC_REQUIRED=false
WITHDRAW_TURNOVER_REQUIRED=true
# Deposit turnover can remain 50% unless you set another value.
WITHDRAW_DEPOSIT_TURNOVER_MULTIPLIER=0.5
# Bonus 100 equivalent requires 200 equivalent bets before withdrawal.
WITHDRAW_BONUS_TURNOVER_MULTIPLIER=2
WITHDRAW_TURNOVER_MULTIPLIER=1

# Agent commission rules
# Deposit 100 => 6 commission, withdraw 100 => 2 commission.
AGENT_DEPOSIT_COMMISSION_RATE=0.06
AGENT_WITHDRAW_COMMISSION_RATE=0.02
AGENT_COMMISSION_PAYOUT_DAY=3
AGENT_COMMISSION_AUTO_PAYOUT=true
AGENT_COMMISSION_PAYOUT_TIMEZONE=Asia/Dhaka
AGENT_COMMISSION_PAYOUT_CHECK_MS=3600000
