# Production sportsbook mode with real OpticOdds data.
# Use your real key only in Render/env settings, never in frontend source code.
SPORTS_PROVIDER=opticodds
SPORTS_ODDS_PROVIDER=opticodds
SPORTS_SCORE_PROVIDER=opticodds
SPORTS_DETAILS_PROVIDER=opticodds,sportmonks,api-sports,theoddsapi
SPORTS_MULTI_DETAILS_ENABLED=true

OPTICODDS_API_KEY=your_opticodds_api_key
OPTICODDS_API_BASE_URL=https://api.opticodds.com/api/v3
OPTICODDS_DEFAULT_SPORTS=cricket,soccer,basketball,tennis,baseball,hockey,football,rugby,volleyball,mma,boxing,table_tennis,darts,esports
OPTICODDS_DEFAULT_SPORTBOOKS=pinnacle,betfair_exchange,bet365,draftkings,betmgm
OPTICODDS_DEFAULT_MARKETS=moneyline,point_spread,total
OPTICODDS_FIXTURE_LIMIT=120
OPTICODDS_TIMEOUT_MS=15000
OPTICODDS_GRADER_ENABLED=true
OPTICODDS_GRADER_SHOW_LIVE_RESULTS=false
OPTICODDS_GRADER_VOID_SUBSTITUTES=true
OPTICODDS_ALLOW_STREAM_FALLBACK=true

# Low-cost odds key. Put the same key in both names for compatibility.
THE_ODDS_API_KEY=your_the_odds_api_key
SPORTS_ODDS_API_KEY=your_the_odds_api_key
SPORTS_DEFAULT_REGIONS=uk,eu,us,au
SPORTS_DEFAULT_MARKETS=h2h
SPORTS_ODDS_FORMAT=decimal
SPORTS_PREFERRED_BOOKMAKERS=bet365,pinnacle,williamhill,betfair,unibet

# Start with a limited sports list to save credits. Use "all" only after checking cost/credits.
SPORTS_AUTO_SYSTEM_ENABLED=true
SPORTS_AUTO_SYNC_ON_REQUEST=true
SPORTS_BACKGROUND_SYNC_ENABLED=true
SPORTS_BACKGROUND_RUN_ON_START=true
SPORTS_BACKGROUND_SYNC_SECONDS=45
SPORTS_BACKGROUND_SETTLEMENT_SECONDS=60
SPORTS_AUTO_SYNC_ACTIVE_SPORTS=false
SPORTS_AUTO_SPORT_KEYS=cricket,soccer,basketball,tennis,baseball,hockey,football,rugby,volleyball,mma,boxing,table_tennis,darts,esports
SPORTS_AUTO_MAX_SPORTS_PER_SYNC=12
SPORTS_MAX_KEYS_PER_GROUP=1
SPORTS_PRIORITY_SPORT_PREFIXES=soccer_,cricket_,basketball_,tennis_,baseball_,icehockey_,americanfootball_,rugbyleague_,rugbyunion_,volleyball,handball_,aussierules_,mma_,boxing_

# Existing SportMonks Cricket details. Odds may remain empty there; The Odds API supplies bet markets.
SPORTMONKS_CRICKET_ENABLED=true
SPORTMONKS_CRICKET_API_TOKEN=your_sportmonks_cricket_token
SPORTMONKS_CRICKET_BASE_URL=https://cricket.sportmonks.com/api/v2.0
SPORTMONKS_CRICKET_INCLUDE=localteam,visitorteam,league,season,stage,venue,scoreboards,runs,balls,batting,bowling,lineup,tosswon,manofmatch,manofseries,odds
SPORTMONKS_CRICKET_MATCH_THRESHOLD=0.35
SPORTMONKS_CRICKET_TIMEOUT_MS=12000

# Optional cheap football/other sport full details from API-SPORTS. Leave empty if you only need basic odds/details.
APISPORTS_API_KEY=
APISPORTS_MATCH_THRESHOLD=0.35
APISPORTS_TIMEOUT_MS=12000
APISPORTS_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
APISPORTS_BASKETBALL_BASE_URL=https://v1.basketball.api-sports.io
APISPORTS_BASEBALL_BASE_URL=https://v1.baseball.api-sports.io
APISPORTS_HOCKEY_BASE_URL=https://v1.hockey.api-sports.io
APISPORTS_AMERICAN_FOOTBALL_BASE_URL=https://v1.american-football.api-sports.io
APISPORTS_RUGBY_BASE_URL=https://v1.rugby.api-sports.io
APISPORTS_VOLLEYBALL_BASE_URL=https://v1.volleyball.api-sports.io
APISPORTS_HANDBALL_BASE_URL=https://v1.handball.api-sports.io
APISPORTS_AFL_BASE_URL=https://v1.afl.api-sports.io
APISPORTS_MMA_BASE_URL=https://v1.mma.api-sports.io

# Football SportMonks is disabled unless you buy SportMonks Football separately.
SPORTMONKS_FOOTBALL_ENABLED=false
SPORTMONKS_FOOTBALL_API_TOKEN=
SPORTMONKS_FOOTBALL_BASE_URL=https://api.sportmonks.com/v3/football

# Betting safety. Only show/bet events that have real provider odds.
SPORTS_USE_PROVIDER_ODDS_ONLY=true
SPORTS_USE_BOOK_ODDS_ONLY=true
SPORTS_REQUIRE_REAL_ODDS=true
SPORTS_DISABLE_FAKE_ODDS=true
SPORTS_DISABLE_SYNTHETIC_ODDS=true
SPORTS_HIDE_EVENTS_WITHOUT_ODDS=true
SPORTS_DRAW_FOR_ALL=false
SPORTS_SYNTHETIC_DRAW_ENABLED=false

SPORTS_ODDS_SYNC_TTL_SECONDS=5
SPORTS_SCORE_SYNC_TTL_SECONDS=5
SPORTS_RESPONSE_CACHE_SECONDS=6
SPORTS_CATEGORIES_CACHE_SECONDS=30
SPORTS_DETAILS_CACHE_SECONDS=120
SPORTS_HIDE_STARTED_OLDER_HOURS=48
SPORTS_RESPONSE_MATCH_LIMIT=120

SPORTS_MIN_STAKE=1
SPORTS_MAX_STAKE=500
SPORTS_LIVE_BETTING_ENABLED=true
SPORTS_BET_CLOSE_BEFORE_START_SECONDS=0
SPORTS_AUTO_SETTLEMENT_ENABLED=true
SPORTS_AUTO_SETTLEMENT_MIN_DELAY_MINUTES=15
SPORTS_AUTO_REVIEW_ABOVE_AMOUNT=0

# Signup bonus / Withdraw rules
# Every new account receives BDT 100 equivalent in the user's registered currency.
SIGNUP_BONUS_ENABLED=true
SIGNUP_BONUS_BASE_AMOUNT_BDT=100
SIGNUP_BONUS_TURNOVER_MULTIPLIER=2
# Optional: set manual BDT -> currency rates if you do not want fallback rates.
# Example: {"USD":0.0082,"INR":0.68,"PKR":2.28}
SIGNUP_BONUS_BDT_RATES_JSON=
# Optional: directly set exact bonus amount per currency.
# Example: {"BDT":100,"INR":68,"USD":0.82}
SIGNUP_BONUS_AMOUNT_BY_CURRENCY_JSON=
SIGNUP_BONUS_EXCHANGE_API_URL=
SIGNUP_BONUS_USE_LIVE_RATES=true
SIGNUP_BONUS_RATE_CACHE_MS=21600000

# Legacy first-deposit bonus is OFF by default because signup bonus is active.
FIRST_DEPOSIT_BONUS_ENABLED=false

# No account/KYC document verification required for withdraw/deposit/bonus.
WITHDRAW_KYC_REQUIRED=false
WITHDRAW_TURNOVER_REQUIRED=true
# Deposit turnover can remain 50% unless you set another value.
WITHDRAW_DEPOSIT_TURNOVER_MULTIPLIER=0.5
# Bonus 100 equivalent requires 200 equivalent bets before withdrawal.
WITHDRAW_BONUS_TURNOVER_MULTIPLIER=2
WITHDRAW_TURNOVER_MULTIPLIER=1

# Agent commission rules
# Deposit 100 => 6 commission, withdraw 100 => 2 commission.
AGENT_DEPOSIT_COMMISSION_RATE=0.06
AGENT_WITHDRAW_COMMISSION_RATE=0.02
AGENT_COMMISSION_PAYOUT_DAY=3
AGENT_COMMISSION_AUTO_PAYOUT=true
AGENT_COMMISSION_PAYOUT_TIMEZONE=Asia/Dhaka
AGENT_COMMISSION_PAYOUT_CHECK_MS=3600000

# Sports stale/live cleanup windows
SPORTS_LIVE_MAX_AGE_HOURS=6
SPORTS_CRICKET_LIVE_MAX_AGE_HOURS=10
SPORTS_FOOTBALL_LIVE_MAX_AGE_HOURS=4
SPORTS_HIDE_STARTED_OLDER_HOURS=6
SPORTS_MAX_EVENT_RETENTION_HOURS=72

# International-style sportsbook loading snapshots
# Worker prebuilds compact sports lobby responses so API requests read one fast snapshot doc.
SPORTS_SNAPSHOT_ENABLED=true
SPORTS_SNAPSHOT_READ_ENABLED=true
SPORTS_SNAPSHOT_WRITE_ENABLED=true
SPORTS_SNAPSHOT_PREBUILD_SECONDS=60
SPORTS_SNAPSHOT_OVERVIEW_TTL_SECONDS=45
SPORTS_SNAPSHOT_MATCHES_TTL_SECONDS=20
SPORTS_SNAPSHOT_LIVE_MATCHES_TTL_SECONDS=5
SPORTS_SNAPSHOT_PREMATCH_MATCHES_TTL_SECONDS=45
SPORTS_LIVE_ODDS_SYNC_ENABLED=true
SPORTS_LIVE_ODDS_SYNC_SECONDS=5
SPORTS_LIVE_ODDS_POLL_LIMIT=80
SPORTS_LIVE_SNAPSHOT_PREBUILD_SECONDS=5
SPORTS_PREMATCH_SNAPSHOT_PREBUILD_SECONDS=45
SPORTS_SNAPSHOT_ALLOW_STALE_SECONDS=45
SPORTS_SNAPSHOT_OVERVIEW_LIMITS=12,16
SPORTS_SNAPSHOT_MATCH_LIMITS=12,24
SPORTS_SNAPSHOT_STATUSES=live,prematch
SPORTS_SNAPSHOT_PRIORITY_SPORTS=all,football,cricket,tennis,basketball,baseball
SPORTS_SNAPSHOT_MAX_DYNAMIC_SPORTS=8
SPORTS_SNAPSHOT_MAX_SPORTS=10
SPORTS_SYNC_STATUS_CACHE_SECONDS=30

OPTICODDS_LIVE_SCORE_POLL_SECONDS=5
OPTICODDS_LIVE_SCORE_POLL_LIMIT=150

# ============================================================================
# PG SOFT Seamless Wallet (HTML Scheme / iframe)
# Provider-issued values must be inserted before enabling production traffic.
# ============================================================================
PGSOFT_ENV=staging
PGSOFT_ENABLED=false
PGSOFT_API_DOMAIN=
PGSOFT_OPERATOR_TOKEN=
PGSOFT_SECRET_KEY=

# Public backend origin used to build the one-time iframe URL.
PGSOFT_PUBLIC_API_ORIGIN=https://api.7xbet.asia

# PG SOFT's outgoing callback IPs only (comma-separated). Obtain these from PG.
# Do not put the 7XBET server IP in this field.
PGSOFT_CALLBACK_ALLOWED_IPS=

# Optional HMAC authentication. Ask PG SOFT to enable it and provide the salt.
PGSOFT_HASH_AUTH_ENABLED=false
PGSOFT_HASH_SALT=
PGSOFT_HASH_VALIDATE_DATE=true
PGSOFT_REQUIRE_TRACE_ID=true

# Integration form configuration.
PGSOFT_SUPPORTED_CURRENCIES=BDT,INR,PKR,NPR,LKR,USD
PGSOFT_FALLBACK_CURRENCY=USD
PGSOFT_CURRENCY_CONVERSION_OWNER=operator
PGSOFT_PLAYER_PREFIX=7xbet_
PGSOFT_DEFAULT_LANGUAGE=en
PGSOFT_DEFAULT_BET_TYPE=1

# Launch/session controls.
PGSOFT_SESSION_TTL_MINUTES=60
PGSOFT_LAUNCH_TICKET_TTL_SECONDS=90
PGSOFT_SINGLE_ACTIVE_SESSION=true
PGSOFT_GAME_EXIT_URL=https://7xbet.asia/pgsoft-games
PGSOFT_ORIENTATION_CHECK=1
PGSOFT_GROUP_ID=
PGSOFT_WEB_LOBBY_WIDTH=930
PGSOFT_ENABLE_WEB_LOBBY=true
PGSOFT_REQUEST_TIMEOUT_MS=9000
PGSOFT_LAUNCH_RETRY_COUNT=1

# Optional official game list supplied by PG SOFT (single-line JSON array).
# Example: [{"id":"1","title":"PG Game 1","image":"/images/pgsoft/1.webp"}]
PGSOFT_GAME_LIST_JSON=

# PG SOFT restriction list from Integration Document v2.4.11.
PGSOFT_RESTRICTED_COUNTRY_CODES=MY,SG,TW,US,MO,IL,IR,KP,AU,GB
