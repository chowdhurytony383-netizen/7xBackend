{
  "name": "7xbet-backend",
  "version": "1.0.0",
  "description": "Complete Express/Mongo backend for the 7XBET React frontend.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "seed": "node src/seed/seed.js",
    "check": "node --check src/server.js",
    "crypto:addresses": "node src/seed/createCryptoAddressesForUsers.js",
    "crypto:subscriptions": "node src/seed/createCryptoSubscriptions.js",
    "crypto:credit-pending": "node src/seed/creditPendingCryptoDeposits.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.7",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "razorpay": "^2.9.4",
    "validator": "^13.12.0",
    "cloudinary": "^2.5.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}